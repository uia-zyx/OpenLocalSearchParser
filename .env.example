APP_ENV=local
APP_NAME=LocaScanScribe.AI
CORS_ORIGINS=["http://localhost:3000"]
FRONTEND_BASE_URL=http://localhost:3000
OPENWEBUI_WEB_SEARCH_API_KEY=locascan-openwebui-local-key

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=locascan
POSTGRES_USER=locascan
POSTGRES_PASSWORD=locascan

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=document_chunks

REDIS_URL=redis://redis:6379/0

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET_DOCUMENTS=documents

LLAMA_OCR_BASE_URL=http://llama-ocr:8080/v1
LLAMA_OCR_MODEL=glm-ocr
PDF_OCR_RENDER_SCALE=1.25
PDF_OCR_JPEG_QUALITY=85
PDF_OCR_CONCURRENCY=2

LLAMA_EMBEDDING_BASE_URL=http://llama-embedding:8080/v1
LLAMA_EMBEDDING_MODEL=qwen3-embedding
EMBEDDING_DIMENSIONS=1024

DEFAULT_IMAGE_STRATEGY=ocr_model
DEFAULT_PDF_STRATEGY=scanner_ocr
MAX_UPLOAD_SIZE_MB=200

